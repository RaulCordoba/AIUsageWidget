<Application x:Class="AIUsageWidget.App.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Application.Resources>
        <SolidColorBrush x:Key="WidgetBackgroundBrush" Color="#E61C1C1E" />
        <SolidColorBrush x:Key="SubtleBorderBrush" Color="#3AFFFFFF" />
        <SolidColorBrush x:Key="TextBrush" Color="#FFFFFFFF" />
        <SolidColorBrush x:Key="MutedTextBrush" Color="#B8FFFFFF" />
        <Style TargetType="Button">
            <Setter Property="Foreground" Value="White" />
            <Setter Property="Background" Value="#25262A" />
            <Setter Property="BorderBrush" Value="#3AFFFFFF" />
            <Setter Property="Padding" Value="10,6" />
            <Setter Property="Cursor" Value="Hand" />
        </Style>
        <Style TargetType="ProgressBar">
            <Setter Property="Height" Value="12" />
            <Setter Property="Foreground" Value="#FB923C" />
            <Setter Property="Background" Value="#2F3035" />
        </Style>
    </Application.Resources>
</Application>
