<Window x:Class="AIUsageWidget.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:converters="clr-namespace:AIUsageWidget.App.Converters"
        Title="AI Usage Widget"
        Width="{Binding WindowWidth}"
        Height="{Binding WindowHeight}"
        WindowStyle="None"
        AllowsTransparency="True"
        ResizeMode="NoResize"
        Background="Transparent"
        Topmost="True"
        ShowInTaskbar="{Binding Settings.ShowInTaskbar}"
        Opacity="{Binding Settings.Opacity}"
        MouseLeftButtonDown="Window_MouseLeftButtonDown"
        MouseLeftButtonUp="Window_MouseLeftButtonUp"
        MouseDoubleClick="Window_MouseDoubleClick"
        LocationChanged="Window_LocationChanged"
        Closing="Window_Closing"
        SourceInitialized="Window_SourceInitialized"
        Deactivated="Window_Deactivated"
        StateChanged="Window_StateChanged">
    <Window.Resources>
        <converters:PercentageTextConverter x:Key="PercentageTextConverter" />
        <converters:BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />
        <converters:PercentageWidthConverter x:Key="PercentageWidthConverter" />
        <Style x:Key="CompactProgressBarStyle" TargetType="ProgressBar">
            <Setter Property="Height" Value="13" />
            <Setter Property="Background" Value="#303136" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ProgressBar">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="7"
                                SnapsToDevicePixels="True">
                            <Grid ClipToBounds="True">
                                <Border x:Name="PART_Indicator"
                                        HorizontalAlignment="Left"
                                        Background="{TemplateBinding Foreground}"
                                        CornerRadius="7" />
                            </Grid>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Border CornerRadius="9"
            Background="{StaticResource WidgetBackgroundBrush}"
            BorderBrush="{StaticResource SubtleBorderBrush}"
            BorderThickness="1"
            Padding="8,6">
        <Border.ContextMenu>
            <ContextMenu>
                <MenuItem Header="Alternar compacto/expandido" Command="{Binding ToggleModeCommand}" />
                <MenuItem Header="Actualizar ahora" Command="{Binding RefreshCommand}" />
                <MenuItem Header="Colocar junto a barra de tareas" Click="DockToTaskbarWidget_Click" />
                <MenuItem Header="Configuracion" Command="{Binding OpenSettingsCommand}" />
                <Separator />
                <MenuItem Header="Ocultar" Command="{Binding HideCommand}" />
            </ContextMenu>
        </Border.ContextMenu>
        <Border.Effect>
            <DropShadowEffect BlurRadius="12" ShadowDepth="1" Opacity="0.28" />
        </Border.Effect>

        <Grid>
            <Grid>
                <Grid.Style>
                    <Style TargetType="Grid">
                        <Setter Property="Visibility" Value="Collapsed" />
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding Settings.CompactMode}" Value="True">
                                <Setter Property="Visibility" Value="Visible" />
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Grid.Style>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="30" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <Grid Grid.Column="0" VerticalAlignment="Center">
                    <Border Width="21" Height="21" CornerRadius="5" Background="#D97745" HorizontalAlignment="Left" VerticalAlignment="Center">
                        <TextBlock Text="&#x2733;" Foreground="White" FontSize="12" FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Center" />
                    </Border>
                </Grid>

                <Border Grid.Column="1"
                        Background="#9A25262A"
                        BorderBrush="#2EFFFFFF"
                        BorderThickness="1"
                        CornerRadius="7"
                        Padding="8,4"
                        VerticalAlignment="Center"
                        Height="38">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="16" />
                            <RowDefinition Height="14" />
                        </Grid.RowDefinitions>
                        <Grid Grid.Row="0">
                            <Border x:Name="CompactProgressTrack"
                                    Height="13"
                                    Background="#303136"
                                    CornerRadius="7"
                                    ClipToBounds="True"
                                    VerticalAlignment="Center">
                                <Border Height="13"
                                        HorizontalAlignment="Left"
                                        Background="{Binding UsageBrush}"
                                        CornerRadius="7">
                                    <Border.Width>
                                        <MultiBinding Converter="{StaticResource PercentageWidthConverter}">
                                            <Binding ElementName="CompactProgressTrack" Path="ActualWidth" />
                                            <Binding Path="PrimaryUsage" />
                                        </MultiBinding>
                                    </Border.Width>
                                </Border>
                            </Border>
                            <TextBlock Text="{Binding PrimaryUsage, Converter={StaticResource PercentageTextConverter}}"
                                       Foreground="White"
                                       FontSize="11"
                                       FontWeight="Bold"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center" />
                        </Grid>
                        <DockPanel Grid.Row="1" LastChildFill="True" Margin="0,1,0,0">
                            <Ellipse Width="5" Height="5" Fill="{Binding ConnectionBrush}" DockPanel.Dock="Left" VerticalAlignment="Center" Margin="0,0,5,0" />
                            <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" Margin="6,0,0,0">
                                <Button Command="{Binding RefreshCommand}" Width="14" Height="14" Padding="0" Background="Transparent" BorderThickness="0" ToolTip="Actualizar ahora">
                                    <TextBlock Text="&#xE72C;" FontFamily="Segoe MDL2 Assets" FontSize="7" Foreground="{StaticResource MutedTextBrush}" />
                                </Button>
                                <Button Command="{Binding OpenSettingsCommand}" Width="14" Height="14" Padding="0" Margin="1,0,0,0" Background="Transparent" BorderThickness="0" ToolTip="Configuracion">
                                    <TextBlock Text="&#xE713;" FontFamily="Segoe MDL2 Assets" FontSize="7" Foreground="{StaticResource MutedTextBrush}" />
                                </Button>
                            </StackPanel>
                            <TextBlock Text="{Binding CompactResetLine}"
                                       Foreground="{StaticResource MutedTextBrush}"
                                       FontSize="10"
                                       TextTrimming="CharacterEllipsis"
                                       VerticalAlignment="Center" />
                        </DockPanel>
                    </Grid>
                </Border>
            </Grid>

            <Grid Visibility="{Binding Settings.CompactMode, Converter={StaticResource BooleanToVisibilityConverter}, ConverterParameter=Invert}">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <DockPanel Margin="0,0,0,12">
                    <TextBlock Text="{Binding HeaderText}" Foreground="White" FontSize="18" FontWeight="SemiBold" DockPanel.Dock="Left" />
                    <StackPanel Orientation="Horizontal" DockPanel.Dock="Right">
                        <Button Command="{Binding RefreshCommand}" Width="30" Height="26" Padding="0" ToolTip="Actualizar ahora">
                            <TextBlock Text="&#xE72C;" FontFamily="Segoe MDL2 Assets" FontSize="12" />
                        </Button>
                        <Button Command="{Binding OpenSettingsCommand}" Width="30" Height="26" Padding="0" Margin="8,0,0,0" ToolTip="Configuracion">
                            <TextBlock Text="&#xE713;" FontFamily="Segoe MDL2 Assets" FontSize="12" />
                        </Button>
                        <Button Command="{Binding HideCommand}" Width="30" Height="26" Padding="0" Margin="8,0,0,0" ToolTip="Ocultar">
                            <TextBlock Text="&#xE8BB;" FontFamily="Segoe MDL2 Assets" FontSize="11" />
                        </Button>
                    </StackPanel>
                </DockPanel>

                <Grid Grid.Row="1" Margin="0,0,0,12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0" Margin="0,0,8,0">
                        <TextBlock Text="Uso de sesion" Foreground="{StaticResource MutedTextBrush}" />
                        <ProgressBar Minimum="0" Maximum="100" Value="{Binding SessionUsage, Mode=OneWay, FallbackValue=0, TargetNullValue=0}" Foreground="{Binding UsageBrush}" Margin="0,5,0,2" />
                        <TextBlock Text="{Binding SessionUsage, Converter={StaticResource PercentageTextConverter}}" Foreground="White" />
                    </StackPanel>
                    <StackPanel Grid.Column="1" Margin="8,0,0,0">
                        <TextBlock Text="Uso semanal" Foreground="{StaticResource MutedTextBrush}" />
                        <ProgressBar Minimum="0" Maximum="100" Value="{Binding WeeklyUsage, Mode=OneWay, FallbackValue=0, TargetNullValue=0}" Foreground="{Binding UsageBrush}" Margin="0,5,0,2" />
                        <TextBlock Text="{Binding WeeklyUsage, Converter={StaticResource PercentageTextConverter}}" Foreground="White" />
                    </StackPanel>
                </Grid>

                <Grid Grid.Row="2">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="1.1*" />
                        <ColumnDefinition Width="1.2*" />
                    </Grid.ColumnDefinitions>
                    <StackPanel>
                        <TextBlock Text="{Binding ResetLine}" Foreground="White" FontSize="14" />
                        <TextBlock Text="{Binding RequestLine}" Foreground="{StaticResource MutedTextBrush}" Margin="0,8,0,0" />
                        <TextBlock Text="{Binding TokenLine}" Foreground="{StaticResource MutedTextBrush}" Margin="0,4,0,0" />
                        <TextBlock Text="{Binding CostLine}" Foreground="{StaticResource MutedTextBrush}" Margin="0,4,0,0" />
                        <TextBlock Text="{Binding ModelLine}" Foreground="{StaticResource MutedTextBrush}" Margin="0,4,0,0" />
                        <TextBlock Text="{Binding StatusMessage}" Foreground="{StaticResource MutedTextBrush}" TextWrapping="Wrap" Margin="0,8,0,0" />
                    </StackPanel>
                    <Border Grid.Column="1" Background="#18191C" CornerRadius="6" Padding="8" Margin="12,0,0,0">
                        <Polyline Points="{Binding HistoryPoints}" Stroke="{Binding UsageBrush}" StrokeThickness="2" Stretch="Fill" />
                    </Border>
                </Grid>
            </Grid>
        </Grid>
    </Border>
</Window>
